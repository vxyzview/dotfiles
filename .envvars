#!/usr/bin/env bash
# shellcheck disable=SC2199,SC2086

# =====================
# Environment Variables
# =====================

# Core Configuration
export QT_QPA_PLATFORMTHEME="gtk3"
export VISUAL="nvim"
export EDITOR="geany"
export TERM="alacritty"
export HISTCONTROL="ignoredups:erasedups"
export XCURSOR_THEME="oreo_white_cursors"
export PAGER="less"

# Locale Settings
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

# XDG Base Directories
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"

# ==============
# Path Configuration
# ==============

path_dirs=(
    "$HOME/.local/bin"
    "$HOME/bin"
    "$CARGO_HOME/bin"               # Rust
    "$GOPATH/bin"                   # Go
    "$GEM_HOME/bin"                 # Ruby
    "/usr/lib/jvm/java-11-openjdk/bin" # Java
    "$HOME/.node_modules_global/bin" # Node.js
    "$HOME/.cargo/bin"              # Rust (alternative)
)

export PATH=$(IFS=:; echo "${path_dirs[*]}"):$PATH

# ====================
# Development Environment
# ====================

# Python Configuration
export PYTHONPATH="${HOME}/.local/lib/python3.x/site-packages:${PYTHONPATH}"
export VIRTUAL_ENV_DISABLE_PROMPT=1
export PIP_CONFIG_FILE="${XDG_CONFIG_HOME}/pip/pip.conf"

# Node.js Configuration
export NODE_PATH="${HOME}/.node_modules_global/lib/node_modules"
export NVM_DIR="${HOME}/.nvm"
[[ -s "${NVM_DIR}/nvm.sh" ]] && source "${NVM_DIR}/nvm.sh"

# Java Configuration
export JAVA_HOME="/usr/lib/jvm/java-11-openjdk"

# Ruby Configuration
export GEM_HOME="${HOME}/.gem"
export RUBY_VERSION="2.7.4"

# Go Configuration
export GOPATH="${HOME}/go"

# Rust Configuration
export CARGO_HOME="${HOME}/.cargo"

# ====================
# Application Specific
# ====================

# Git Configuration
export GIT_EDITOR="nvim"
export GIT_CONFIG_GLOBAL="${XDG_CONFIG_HOME}/git/config"
export GIT_PAGER="less -F -X"

# Docker Configuration
export DOCKER_BUILDKIT=1
export DOCKER_DEFAULT_PLATFORM="linux/amd64"

# Neovim Configuration
export NVIM_APPNAME="nvim"

# Xdeb Configuration (Void Linux)
export XDEB_OPT_DEPS="true"
export XDEB_OPT_SYNC="true"
export XDEB_OPT_WARN_CONFLICT="true"
export XDEB_OPT_FIX_CONFLICT="true"

# ====================
# Optional Configurations
# ====================

# PostgreSQL Environment
# export PGUSER="your_pg_user"
# export PGHOST="localhost"
# export PGPORT="5432"
# export PGDATABASE="your_pg_database"

# MySQL Environment
# export MYSQL_HOME="${XDG_CONFIG_HOME}/mysql/my.cnf"
# export MYSQL_PWD="your_mysql_password"
