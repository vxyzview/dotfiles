#!/usr/bin/env bash
#
# System Control Script - Manage brightness, volume, and mute state
#
# Copyright (C) 2024 pyranix <pyranix@proton.me>
# Licensed under Apache License 2.0

# Constants
readonly NOTIFY_ID=424242
readonly STACK_TAG="system-control"
readonly ICON_VOLUME="$HOME/.notify/images/music.png"
readonly ICON_MUTE="$HOME/.notify/images/mute.png"
readonly ICON_BRIGHTNESS="$HOME/.notify/images/smart-bulb.png"

# Show notification with progress bar
show_notification() {
    local title="$1"
    local state="$2"
    local icon="$3"
    local level="$4"

    dunstify -u low -i "$icon" -r "$NOTIFY_ID" \
        -h "int:value:$level" \
        -h "string:x-dunst-stacktag:$STACK_TAG" \
        "$title" "${state}: ${level}%"
}

# Get current brightness percentage
get_brightness() {
    brightnessctl -m | awk -F, '{gsub(/%/, "", $4); print $4}'
}

# Get current volume percentage (average of channels)
get_volume() {
    pactl get-sink-volume @DEFAULT_SINK@ | 
    awk '{
        gsub(/%/, "", $5); 
        gsub(/%/, "", $12); 
        print ($5 + $12)/2
    }' | xargs printf "%.0f"
}

# Validate numeric input argument
validate_number() {
    [[ "$1" =~ ^[+-]?[0-9]+([.][0-9]+)?$ ]] || {
        echo >&2 "Invalid numeric value: $1"
        exit 2
    }
}

# Change brightness with validation
set_brightness() {
    validate_number "$1"
    brightnessctl set "$1" >/dev/null || {
        echo >&2 "Failed to adjust brightness"
        exit 3
    }
    show_notification "Brightness" "Adjusted" "$ICON_BRIGHTNESS" "$(get_brightness)"
}

# Change volume with validation
set_volume() {
    validate_number "$1"
    pactl set-sink-volume @DEFAULT_SINK@ "${1}%" || {
        echo >&2 "Failed to adjust volume"
        exit 4
    }
    show_notification "Volume" "Adjusted" "$ICON_VOLUME" "$(get_volume)"
}

# Toggle mute state
toggle_mute() {
    pactl set-sink-mute @DEFAULT_SINK@ toggle || {
        echo >&2 "Failed to toggle mute state"
        exit 5
    }
    
    local status="$(pactl get-sink-mute @DEFAULT_SINK@ | awk '{print $2}')"
    if [[ "$status" == "yes" ]]; then
        show_notification "Audio" "Muted" "$ICON_MUTE" 0
    else
        show_notification "Audio" "Unmuted" "$ICON_VOLUME" "$(get_volume)"
    fi
}

# Show usage information
usage() {
    cat <<EOF
System Control - Manage brightness and audio

Usage: $0 <command> [value]

Commands:
  brightness <value>    Set brightness percentage (e.g., 50, +10, -5)
  volume <value>        Set volume percentage (e.g., 75, +5, -10)
  mute                  Toggle mute state

Examples:
  $0 brightness 70      # Set brightness to 70%
  $0 volume +5          # Increase volume by 5%
  $0 mute               # Toggle mute state
EOF
}

# Main control flow
main() {
    [[ $# -eq 0 ]] && { usage; exit 1; }

    case "$1" in
        brightness|volume)
            [[ -z "$2" ]] && { echo >&2 "Missing value for $1"; exit 1; }
            "set_${1}" "$2"
            ;;
        mute)
            toggle_mute
            ;;
        -h|--help)
            usage
            ;;
        *)
            echo >&2 "Invalid command: $1"
            usage
            exit 1
            ;;
    esac
}

main "$@"
exit 0
