#!/bin/bash
set -eo pipefail

# Constants and configuration
SUPPORTED_ALGORITHMS=("tar" "gzip" "bzip2" "zip" "lz4" "zstd")
VERSION="1.1.0"
OPENSSL_CMD="openssl enc -aes-256-cbc -salt -pbkdf2"

# Display help information
show_help() {
    cat <<EOF
File Compression Tool v${VERSION}
Usage: ${0##*/} [-e] [-a ALGORITHM] [-p PASSWORD] -o OUTPUT INPUT...

Options:
  -e, --encrypt      Enable file encryption
  -a, --algorithm    Compression algorithm (default: tar)
                     Supported: ${SUPPORTED_ALGORITHMS[@]}
  -p, --password     Encryption password (required for -e)
  -o, --output       Output file base name (extensions auto-added)
  -h, --help         Show this help message
  -v, --version      Display version information

Examples:
  # Create encrypted zip archive
  ${0##*/} -e -a zip -p "secret" -o backup ~/Documents

  # Compress using zstd without encryption
  ${0##*/} -a zstd -o project-archive ~/projects/src
EOF
}

# Display version information
show_version() {
    echo "File Compression Tool v${VERSION}"
}

# Error handling functions
error() {
    echo "Error: $1" >&2
    exit 1
}

check_dependency() {
    command -v "$1" >/dev/null 2>&1 || error "Required command '$1' not found"
}

# Compression handlers
tar_based_compression() {
    local compression="$1"
    local extension="$2"
    local tar_opts=()

    case "$compression" in
        gzip)   check_dependency gzip; tar_opts=(-z) ;;
        bzip2)  check_dependency bzip2; tar_opts=(-j) ;;
        lz4)    check_dependency lz4; tar_opts=("--use-compress-program=lz4") ;;
        zstd)   check_dependency zstd; tar_opts=("--use-compress-program=zstd") ;;
        *)      tar_opts=() ;;
    esac

    tar "${tar_opts[@]}" -cvf "${OUTPUT_PATH}${extension}" -- "${INPUT_FILES[@]}"
}

zip_compression() {
    check_dependency zip
    zip -qr "${OUTPUT_PATH}.zip" -- "${INPUT_FILES[@]}"
}

# Main workflow
main() {
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -e|--encrypt)   ENCRYPT=true; shift ;;
            -a|--algorithm) ALGORITHM="$2"; shift 2 ;;
            -p|--password)  PASSWORD="$2"; shift 2 ;;
            -o|--output)    OUTPUT_BASE="$2"; shift 2 ;;
            -h|--help)      show_help; exit 0 ;;
            -v|--version)   show_version; exit 0 ;;
            --)             shift; break ;;
            -*)             error "Invalid option: $1" ;;
            *)              INPUT_FILES+=("$1"); shift ;;
        esac
    done

    # Validate inputs
    [[ "${#INPUT_FILES[@]}" -eq 0 ]] && error "No input files specified"
    [[ -z "$OUTPUT_BASE" ]] && error "Output file name required"
    [[ ! " ${SUPPORTED_ALGORITHMS[@]} " =~ " $ALGORITHM " ]] && 
        error "Unsupported algorithm: $ALGORITHM. Valid options: ${SUPPORTED_ALGORITHMS[*]}"

    # Configure paths
    local output_extension
    case "$ALGORITHM" in
        tar)   output_extension=".tar" ;;
        gzip)  output_extension=".tar.gz" ;;
        bzip2) output_extension=".tar.bz2" ;;
        zip)   output_extension=".zip" ;;
        lz4)   output_extension=".tar.lz4" ;;
        zstd)  output_extension=".tar.zst" ;;
    esac
    OUTPUT_PATH="${OUTPUT_BASE}${output_extension}"

    # Perform compression
    case "$ALGORITHM" in
        tar|gzip|bzip2|lz4|zstd) tar_based_compression "$ALGORITHM" "$output_extension" ;;
        zip) zip_compression ;;
    esac || error "Compression failed"

    # Handle encryption
    if [[ "$ENCRYPT" == true ]]; then
        [[ -z "$PASSWORD" ]] && error "Password required for encryption"
        
        local encrypted_path="${OUTPUT_PATH}.enc"
        echo "Encrypting archive..."
        $OPENSSL_CMD -in "$OUTPUT_PATH" -out "$encrypted_path" -pass "pass:$PASSWORD" ||
            error "Encryption failed"
        
        rm -f "$OUTPUT_PATH"
        OUTPUT_PATH="$encrypted_path"
    fi

    echo "Operation completed successfully"
    echo "Output file: ${OUTPUT_PATH}"
}

# Execute main function
main "$@"
