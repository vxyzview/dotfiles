#!/usr/bin/env bash
set -euo pipefail

# Configuration
LOG_FILE="${HOME}/.system_cleanup.log"
CLEAN_DIRS=("${HOME}" "/tmp")
DRY_RUN=false
FORCE=false

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Dependency checks
check_dependencies() {
    local missing=()
    command -v sudo &>/dev/null || missing+=("sudo")
    command -v fdupes &>/dev/null || missing+=("fdupes")

    case $DISTRO in
        arch) command -v pacman &>/dev/null || missing+=("pacman") ;;
        void) command -v xbps-remove &>/dev/null || missing+=("xbps") ;;
    esac

    if [ ${#missing[@]} -gt 0 ]; then
        echo -e "${RED}Missing dependencies: ${missing[*]}${NC}" >&2
        exit 1
    fi
}

# Initialize logging
setup_logging() {
    exec 3>&1 4>&2
    exec > >(tee -a "${LOG_FILE}") 2>&1
    echo -e "\n=== Cleanup started $(date) ==="
}

# Detect Linux distribution
detect_distro() {
    case $(lsb_release -si 2>/dev/null) in
        Arch*|Artix*) echo "arch" ;;
        Void*)        echo "void" ;;
        *)
            [ -f /etc/arch-release ] && echo "arch" && return
            [ -f /etc/void-release ] && echo "void" && return
            echo -e "${RED}Unsupported Linux distribution.${NC}" >&2
            exit 1
            ;;
    esac
}

# Clean package cache
clean_cache() {
    case $DISTRO in
        arch)
            echo -e "${YELLOW}Cleaning Arch Linux cache...${NC}"
            sudo pacman -Sc --noconfirm
            ;;
        void)
            echo -e "${YELLOW}Cleaning Void Linux cache...${NC}"
            sudo xbps-remove -O
            ;;
    esac
}

# Clean duplicate files with safety checks
clean_duplicates() {
    local dir
    echo -e "${YELLOW}Starting duplicate file cleanup...${NC}"
    
    for dir in "${CLEAN_DIRS[@]}"; do
        [ ! -d "$dir" ] && continue
        
        if $DRY_RUN; then
            echo -e "${GREEN}[DRY RUN]${NC} Would clean duplicates in: ${dir}"
            fdupes -r "$dir"
            continue
        fi

        if ! $FORCE; then
            echo -e "${YELLOW}Press Enter to scan duplicates in ${dir} (Ctrl+C to abort)${NC}"
            read -r
        fi

        fdupes -r -dN "$dir" | while read -r line; do
            echo -e "${RED}Removing duplicate:${NC} ${line}"
        done
    done
}

# Remove unused packages
clean_unused() {
    case $DISTRO in
        arch)
            echo -e "${YELLOW}Cleaning Arch packages...${NC}"
            local orphans=$(pacman -Qdtq 2>/dev/null || true)
            
            if [ -n "$orphans" ]; then
                echo -e "${RED}Removing:${NC} ${orphans}"
                $DRY_RUN || sudo pacman -Rns --noconfirm $orphans
            else
                echo -e "${GREEN}No orphaned packages found${NC}"
            fi
            ;;
        void)
            echo -e "${YELLOW}Cleaning Void packages...${NC}"
            if $DRY_RUN; then
                xbps-query -o
            else
                sudo xbps-remove -o
            fi
            ;;
    esac
}

show_help() {
    cat <<EOF
System Cleanup Utility
Usage: ${0##*/} [OPTIONS]

Options:
  --dry-run       Show what would be done without making changes
  --force         Skip confirmation prompts
  --log           Show log file after completion
  --dirs DIRS     Comma-separated directories to check for duplicates
  --help          Show this help message

Configured directories: ${CLEAN_DIRS[*]}
Log file: ${LOG_FILE}
EOF
}

parse_args() {
    while [ $# -gt 0 ]; do
        case $1 in
            --dry-run)    DRY_RUN=true ;;
            --force)      FORCE=true ;;
            --log)        tail -f "${LOG_FILE}" ; exit ;;
            --dirs)       IFS=',' read -ra CLEAN_DIRS <<< "$2"; shift ;;
            --help)       show_help; exit ;;
            *)            echo -e "${RED}Unknown option: $1${NC}"; show_help; exit 1 ;;
        esac
        shift
    done
}

main() {
    parse_args "$@"
    DISTRO=$(detect_distro)
    check_dependencies
    setup_logging
    
    trap 'echo -e "${RED}Cleanup interrupted!${NC}" >&2; exit 1' INT

    clean_cache
    clean_duplicates
    clean_unused

    echo -e "${GREEN}System cleanup completed successfully!${NC}"
    echo -e "Details logged to: ${YELLOW}${LOG_FILE}${NC}"
}

main "$@"
