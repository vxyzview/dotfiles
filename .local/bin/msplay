#!/usr/bin/env bash

# Directory where music files are stored
MUSIC_DIR="${HOME}/Music"

# Check if the Music directory exists
if [[ ! -d "${MUSIC_DIR}" ]]; then
    echo "Music directory not found: ${MUSIC_DIR}"
    exit 1
fi

# Function to get clean name (relative path without extension)
get_clean_name() {
    local file="${1}"
    local rel_path="${file#${MUSIC_DIR}/}"
    echo "${rel_path%.*}"
}

# Function to play music using ffplay
play_music() {
    local selected_file="${1}"
    echo "Playing: $(get_clean_name "${selected_file}")"
    nohup ffplay -nodisp -autoexit -loglevel panic "${selected_file}" >/dev/null 2>&1 &
}

# Use arrays to store music files and clean names
declare -a music_files clean_names

# Find all music files safely
while IFS= read -r -d '' file; do
    music_files+=("${file}")
    clean_names+=("$(get_clean_name "${file}")")
done < <(find "${MUSIC_DIR}" -type f \( -name "*.mp3" -o -name "*.wav" -o -name "*.ogg" -o -name "*.flac" \) -print0)

# Check if there are music files
if [[ ${#music_files[@]} -eq 0 ]]; then
    echo "No music files found in ${MUSIC_DIR}"
    exit 1
fi

# Present action selection
action=$(printf "Start music\nStop music\n" | rofi -dmenu -i -p "Choose action: ")

case "${action}" in
    "Start music")
        # Present selection menu with clean names
        selected=$(printf "%s\n" "${clean_names[@]}" | rofi -dmenu -i -p "Select a song: ")
        
        # Find the corresponding file
        selected_file=""
        for i in "${!clean_names[@]}"; do
            if [[ "${clean_names[i]}" == "${selected}" ]]; then
                selected_file="${music_files[i]}"
                break
            fi
        done

        if [[ -n "${selected_file}" ]]; then
            play_music "${selected_file}"
        else
            echo "Error: Selected file not found."
            exit 1
        fi
        ;;
    "Stop music")
        pkill -f "ffplay -nodisp -autoexit -loglevel panic"
        ;;
    *)
        exit 0
        ;;
esac

exit 0
