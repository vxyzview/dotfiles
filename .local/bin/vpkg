#!/bin/bash
set -eo pipefail
shopt -s nullglob

# Configuration
readonly VP_DIR="${HOME}/.vpkg"
readonly VPKG_CMD="/usr/local/bin/vpkg"
readonly CONF_FILE="${VP_DIR}/etc/conf"
readonly REPO_URL="https://github.com/void-linux/void-packages"

# Text formatting
readonly BOLD=$(tput bold)
readonly GREEN=$(tput setaf 2)
readonly RED=$(tput setaf 1)
readonly RESET=$(tput sgr0)

# Error handling
trap 'error_handler $? $LINENO' ERR
trap 'interrupt_handler' SIGINT

error_handler() {
  local exit_code=$1
  local line_no=$2
  echo -e "\n${RED}${BOLD}Error${RESET} at line ${line_no} - exit code ${exit_code}" >&2
  exit "${exit_code}"
}

interrupt_handler() {
  echo -e "\n${RED}${BOLD}Operation cancelled by user!${RESET}" >&2
  exit 1
}

# Dependency checks
check_dependencies() {
  local deps=("git" "sudo")
  for dep in "${deps[@]}"; do
    if ! command -v "${dep}" >/dev/null 2>&1; then
      echo "${RED}Error: Missing required dependency '${dep}'${RESET}" >&2
      exit 1
    fi
  done
}

# Repository management
setup_repository() {
  if [[ -d "${VP_DIR}/.git" ]]; then
    echo "${BOLD}Using existing repository in ${VP_DIR}${RESET}"
    return 0
  fi

  if [[ -e "${VP_DIR}" ]]; then
    echo "${RED}Error: ${VP_DIR} exists but is not a git repository${RESET}" >&2
    exit 1
  fi

  echo "${BOLD}Cloning void-packages repository...${RESET}"
  git clone --depth=1 "${REPO_URL}" "${VP_DIR}"
}

# Build environment setup
bootstrap_environment() {
  (
    cd "${VP_DIR}"
    if [[ ! -f ./xbps-src ]]; then
      echo "${RED}Error: xbps-src not found in repository${RESET}" >&2
      exit 1
    fi
    
    echo "${BOLD}Bootstrapping build environment...${RESET}"
    ./xbps-src binary-bootstrap
  )
}

# Configuration management
enable_restricted_packages() {
  mkdir -p "${VP_DIR}/etc"
  if ! grep -qx 'XBPS_ALLOW_RESTRICTED=yes' "${CONF_FILE}" 2>/dev/null; then
    echo "${BOLD}Enabling restricted packages...${RESET}"
    echo 'XBPS_ALLOW_RESTRICTED=yes' >> "${CONF_FILE}"
  fi
}

# vpkg command installation
install_vpkg_command() {
  echo "${BOLD}Installing vpkg command...${RESET}"
  sudo tee "${VPKG_CMD}" >/dev/null <<'EOF'
#!/bin/bash
set -eo pipefail

readonly VP_DIR="${HOME}/.vpkg"
readonly PKG_DIR="${VP_DIR}/hostdir/binpkgs"
readonly GREEN=$(tput setaf 2)
readonly RESET=$(tput sgr0)

main() {
  [[ $# -eq 0 ]] && usage
  cd "${VP_DIR}" || exit 1
  
  local package="$1"
  echo "${GREEN}Building package: ${package}${RESET}"
  ./xbps-src pkg "${package}"
  
  echo "${GREEN}Installing package: ${package}${RESET}"
  sudo xbps-install --repository="${PKG_DIR}" "${package}"
  
  echo "${GREEN}Successfully installed ${package}${RESET}"
}

usage() {
  echo "Usage: ${0##*/} <package_name>"
  exit 1
}

main "$@"
EOF

  sudo chmod 755 "${VPKG_CMD}"
}

# Main execution flow
main() {
  check_dependencies
  setup_repository
  bootstrap_environment
  enable_restricted_packages
  install_vpkg_command
  
  echo -e "\n${GREEN}${BOLD}Setup complete!${RESET}"
  echo "Use 'vpkg <package_name>' to build and install packages"
}

main "$@"
