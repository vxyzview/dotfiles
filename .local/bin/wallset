#!/usr/bin/env bash
# shellcheck disable=SC2016,SC2086
#
# Lightweight Wallpaper Manager with Preview and Multi-Monitor Support

WALLPAPER_DIR="${HOME}/.wallpaper"
CACHE_DIR="${HOME}/.cache/wallpaper-manager"
ROFI_THEME=(
    -theme-str 'entry { placeholder: "Search Wallpapers..."; }'
    -theme-str 'listview { lines: 7; }'
)
ROFI_CMD=(-no-custom -location 2 -dmenu -i -kb-custom-1 "Ctrl+p" ${ROFI_THEME[@]})
PREVIEW_CMD="feh --draw-filename --scale-down --preview \"\$FILE\""
VALID_EXTENSIONS=("jpg" "jpeg" "png" "webp" "bmp")

# Initialize required directories
init_directories() {
    mkdir -p "${WALLPAPER_DIR}" "${CACHE_DIR}"
}

# Check system requirements
check_requirements() {
    local missing=()
    command -v rofi >/dev/null || missing+=("rofi")
    command -v feh >/dev/null || missing+=("feh")
    command -v dunstify >/dev/null || missing+=("dunstify")
    command -v convert >/dev/null || missing+=("imagemagick")

    [[ ${#missing[@]} -gt 0 ]] && {
        dunstify -u critical "Missing requirements:" "${missing[*]}"
        exit 1
    }
}

# Generate thumbnail previews
generate_thumbnails() {
    local wall_path="$1"
    local thumb_name="${CACHE_DIR}/$(basename "${wall_path}").thumb.jpg"
    
    [[ -f "${thumb_name}" ]] || convert "${wall_path}" -thumbnail 400x400^ \
        -gravity center -extent 400x400 "${thumb_name}" 2>/dev/null
    echo "${thumb_name}"
}

# Wallpaper selection menu
show_wallpaper_menu() {
    declare -A wall_map
    while IFS= read -r -d $'\0' wall; do
        local fname=$(basename "${wall}")
        wall_map["${fname}"]="${wall}"
    done < <(find "${WALLPAPER_DIR}" -maxdepth 1 -type f \( -iname "*.jpg" -o -iname "*.jpeg" \
        -o -iname "*.png" -o -iname "*.webp" -o -iname "*.bmp" \) -print0)

    local selection
    selection=$(printf '%s\n' "${!wall_map[@]}" | rofi ${ROFI_CMD[@]})
    
    case $? in
        0) echo "${wall_map["${selection}"]}" ;;
        10) show_preview "${wall_map["${selection}"]}" ;;
        *) echo "" ;;
    esac
}

# Preview window
show_preview() {
    local wall_path="$1"
    local thumb=$(generate_thumbnails "${wall_path}")
    
    feh --title "Wallpaper Preview" --scale-down --geometry 800x600 \
        --info "echo 'Resolution: %wx%h\nSize: %b'" "${thumb}" \
        | rofi -dmenu -p "Previewing: $(basename "${wall_path}")" -theme-str '* { background: transparent; }'
}

# Set wallpaper and create gradient overlay
set_wallpaper() {
    local wall_path="$1"
    feh --no-fehbg --bg-fill "${wall_path}"
    
    # Create gradient overlay using imagemagick
    convert "${wall_path}" \( +clone -alpha extract -draw 'fill black polygon 0,0 0,60 60,0' \
        -alpha off -write mpr:clip +delete \) -mask mpr:clip -background "#2e3440" \
        -alpha on -opaque none +mask "${CACHE_DIR}/gradient.png"
    
    dunstify -t 2500 -i "${CACHE_DIR}/gradient.png" "󰆊 Wallpaper Set" \
        "Selected: $(basename "${wall_path}")"
}

# Main workflow
main() {
    init_directories
    check_requirements
    
    local selected_wall
    selected_wall=$(show_wallpaper_menu)
    
    [[ -z "${selected_wall}" ]] && {
        dunstify -t 1500 "󰩃 No wallpaper selected"
        exit 0
    }
    
    [[ -f "${selected_wall}" ]] || {
        dunstify -u critical "󰅖 Error" "Wallpaper file not found!"
        exit 1
    }

    set_wallpaper "${selected_wall}"
}

main "$@"
