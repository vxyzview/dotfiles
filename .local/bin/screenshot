#!/usr/bin/env bash
set -euo pipefail

# ========================
#   CONFIGURATION
# ========================
readonly NOTIFY_ICON=""          # Notification icon
readonly TIMER_ICON=""           # Timer icon
readonly PICTURES_DIR="${XDG_PICTURES_DIR:-$HOME/Pictures}/Screenshots"
readonly SCREENSHOT_PREFIX="Screenshot"  # Filename prefix
readonly SHADOW_OPACITY=25        # Shadow: 25% opacity
readonly SHADOW_BLUR=30           # Shadow: 30px blur
readonly SHADOW_OFFSET="+0+0"     # Shadow: No offset
readonly TIMER_DELAY=0.5          # Capture delay for fullscreen
readonly ROFI_PROMPT="Screenshot" # Rofi prompt text
readonly ROFI_OPTIONS=("full" "5" "10" "window" "area")  # Selection options

# ========================
#   INITIALIZATION
# ========================
TEMP_DIR=$(mktemp -d) && readonly TEMP_DIR
trap 'rm -rf "$TEMP_DIR"' EXIT

# ========================
#   ERROR HANDLING
# ========================
die() {
  local message="$1"
  dunstify -u critical "Screenshot Error" "$message"
  exit 1
}

# ========================
#   DEPENDENCY CHECK
# ========================
check_dependencies() {
  local missing=()
  local deps=("maim" "convert" "xclip" "rofi" "dunstify" "xdotool")

  for cmd in "${deps[@]}"; do
    command -v "$cmd" >/dev/null || missing+=("$cmd")
  done

  ((${#missing[@]})) && die "Missing dependencies: ${missing[*]}"
}

# ========================
#   DIRECTORY MANAGEMENT
# ========================
create_workspace() {
  mkdir -p "$PICTURES_DIR" || die "Failed to create $PICTURES_DIR"
  [[ -w "$PICTURES_DIR" ]] || die "No write permissions in $PICTURES_DIR"
}

# ========================
#   NOTIFICATION SYSTEM
# ========================
notify_success() {
  local image_path="$1"
  dunstify --replace=1 -u low -i "$image_path" \
    "Screenshot Taken" "Image copied to clipboard"
}

# ========================
#   SCREENSHOT PROCESSING
# ========================
generate_filename() {
  echo "${PICTURES_DIR}/${SCREENSHOT_PREFIX}_$(date +%Y-%m-%d-%H-%M-%S).png"
}

add_shadow_effect() {
  convert "$1" \
    \( +clone -background black -shadow "${SHADOW_OPACITY}x${SHADOW_BLUR}${SHADOW_OFFSET}" \) \
    +swap -background "${BG_COLOR:-"#FFFFFF"}" -layers merge +repage \
    "$2" || die "Image processing failed"
}

# ========================
#   CAPTURE FUNCTIONS
# ========================
capture_fullscreen() {
  sleep "$TIMER_DELAY"
  maim -u -f png "$1"
}

capture_window() {
  maim -i "$(xdotool getactivewindow)" "$1"
}

capture_area() {
  maim -s "$1"
}

# ========================
#   MAIN WORKFLOW
# ========================
screenshot_workflow() {
  local capture_type="$1"
  local temp_file="${TEMP_DIR}/capture.png"
  local final_file=$(generate_filename)

  case "$capture_type" in
    full)  capture_fullscreen "$temp_file" ;;
    window) capture_window "$temp_file" ;;
    area)   capture_area "$temp_file" ;;
    *)      die "Invalid capture type: $capture_type" ;;
  esac || die "Capture failed"

  add_shadow_effect "$temp_file" "$final_file"
  xclip -selection clipboard -t image/png -i "$final_file" || die "Clipboard copy failed"
  notify_success "$final_file"
  rm "$temp_file"
}

countdown_workflow() {
  local delay="$1"
  while (( delay > 0 )); do
    dunstify --replace=1 -u low -i "$TIMER_ICON" "Taking shot in:" "$delay"
    sleep 1
    (( delay-- ))
  done
}

# ========================
#   MAIN EXECUTION
# ========================
main() {
  check_dependencies
  create_workspace
  [[ -f "$HOME/.envvars" ]] && source "$HOME/.envvars"

  local selected=$(printf "%s\n" "${ROFI_OPTIONS[@]}" | \
    rofi -dmenu -i -p "$ROFI_PROMPT" -columns 1 -width 30)

  case "$selected" in
    "5"|"10") 
      countdown_workflow "$selected"
      screenshot_workflow "full"
      ;;
    "full"|"window"|"area")
      screenshot_workflow "$selected"
      ;;
    *)
      exit 0  # Normal exit for canceled selection
      ;;
  esac
}

main
