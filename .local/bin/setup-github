#!/usr/bin/env bash
# shellcheck disable=SC1091,SC2155

set -eo pipefail

# Configuration
SSH_KEY_TYPE="ed25519"
SSH_KEY_PATH="${HOME}/.ssh/id_${SSH_KEY_TYPE}"
GITHUB_URL="https://github.com/settings/keys"
SSH_DIR="${HOME}/.ssh"
KNOWN_HOSTS="${SSH_DIR}/known_hosts"

# Colors setup (only if terminal supports it)
if [[ -t 1 ]]; then
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[1;33m'
  BLUE='\033[0;34m'
  NC='\033[0m'
else
  RED='' GREEN='' YELLOW='' BLUE='' NC=''
fi

# Function library
die() { echo -e "${RED}Error: $*${NC}" >&2; exit 1; }
info() { echo -e "${BLUE}$*${NC}"; }
success() { echo -e "${GREEN}$*${NC}"; }
warning() { echo -e "${YELLOW}$*${NC}"; }

# Trap CTRL+C for clean exit
trap 'die "Operation aborted by user"' SIGINT

# Help message
show_help() {
  cat <<EOF
GitHub SSH Setup Script

Usage: $0 [options]

Options:
  -e, --email EMAIL    Set GitHub email
  -n, --name NAME      Set GitHub name
  -f, --force          Overwrite existing keys without prompt
  -q, --quiet          Run in non-interactive mode
  -v, --verbose        Enable verbose output
  -h, --help           Show this help message

EOF
}

# Parse command-line arguments
parse_arguments() {
  while [[ $# -gt 0 ]]; do
    case $1 in
      -e|--email) GIT_EMAIL="$2"; shift 2;;
      -n|--name) GIT_NAME="$2"; shift 2;;
      -f|--force) FORCE=true; shift;;
      -q|--quiet) QUIET=true; shift;;
      -v|--verbose) VERBOSE=true; shift;;
      -h|--help) show_help; exit 0;;
      *) die "Unknown option: $1";;
    esac
  done
}

# Enhanced input validation
validate_email() {
  [[ "$1" =~ ^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}$ ]] || die "Invalid email format"
}

# Security: Check SSH directory permissions
check_ssh_permissions() {
  [[ "$QUIET" == true ]] && return
  
  local ssh_perm
  ssh_perm=$(stat -c "%a" "$SSH_DIR" 2>/dev/null || stat -f "%A" "$SSH_DIR")
  
  if [[ "$ssh_perm" != 700 ]]; then
    warning "Insecure SSH directory permissions (${ssh_perm})"
    chmod 700 "$SSH_DIR"
    success "Updated permissions to 700"
  fi
}

# Test SSH connection to GitHub
test_ssh_connection() {
  info "Testing SSH connection to GitHub..."
  local output
  output=$(ssh -T git@github.com 2>&1 || true)
  
  if [[ "$output" == *"successfully authenticated"* ]]; then
    success "SSH connection successful!"
  else
    warning "SSH connection test failed"
    [[ "$VERBOSE" == true ]] && echo "Output: $output"
  fi
}

# Configure GitHub known hosts
configure_known_hosts() {
  if [[ ! -f "$KNOWN_HOSTS" ]] || ! grep -q "^github.com " "$KNOWN_HOSTS"; then
    info "Configuring known hosts..."
    mkdir -p "$SSH_DIR"
    curl -sS https://api.github.com/meta | jq -r '.ssh_keys[]' | \
      sed -e 's/^/github.com /' >> "$KNOWN_HOSTS"
    success "Known hosts configured"
  fi
}

# Main workflow
configure_git() {
  [[ "$QUIET" == true && (-z "$GIT_EMAIL" || -z "$GIT_NAME") ]] && \
    die "Email and name required in quiet mode"

  if [[ -z "$GIT_EMAIL" ]]; then
    prompt_input "Enter your GitHub email" GIT_EMAIL "^.+@.+\..+$"
  else
    validate_email "$GIT_EMAIL"
  fi

  [[ -z "$GIT_NAME" ]] && prompt_input "Enter your GitHub name" GIT_NAME "^.+$"

  git config --global user.email "${GIT_EMAIL}"
  git config --global user.name "${GIT_NAME}"
}

generate_ssh_key() {
  [[ "$FORCE" == true ]] && rm -f "${SSH_KEY_PATH}" "${SSH_KEY_PATH}.pub"

  if [[ -f "${SSH_KEY_PATH}" ]]; then
    warning "SSH key already exists at ${SSH_KEY_PATH}"
    [[ "$QUIET" != true ]] && read -rp "Generate new? [y/N] " overwrite
    [[ "${overwrite,,}" != "y" && "$QUBOSE" != true ]] && return
  fi

  ssh-keygen -t "${SSH_KEY_TYPE}" -C "${GIT_EMAIL}" -f "${SSH_KEY_PATH}" -N "" -q
}

# Enhanced main function
main() {
  parse_arguments "$@"
  check_requirements
  check_ssh_permissions
  configure_git
  generate_ssh_key
  configure_known_hosts
  copy_ssh_key
  open_github
  test_ssh_connection
  
  success "Setup complete! ${YELLOW}Remember to add the SSH key to your GitHub account!${NC}"
}

# Only run main if not being sourced
[[ "${BASH_SOURCE[0]}" == "$0" ]] && main "$@"
