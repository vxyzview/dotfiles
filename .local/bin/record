#!/usr/bin/env bash

# Strict error handling
set -eo pipefail
shopt -s inherit_errexit

# Configuration
readonly OUTPUT_DIR="${HOME}/Videos/ScreenRecords"
readonly VALID_FPS=(60 90 120 144 240)
declare -Ar QUALITY_PRESETS=(
    [High]="ultrafast:18"
    [Medium]="medium:23"
    [Low]="veryslow:28"
)
readonly REQUIRED_CMDS=(rofi ffmpeg xdpyinfo dunstify)

# Dependency check
check_dependencies() {
    local missing=()
    for cmd in "${REQUIRED_CMDS[@]}"; do
        command -v "${cmd}" >/dev/null || missing+=("${cmd}")
    done
    
    ((${#missing[@]})) && {
        dunstify "Missing dependencies:" "$(printf '%s\n' "${missing[@]}")" --urgency=critical
        exit 1
    }
}

# Get user selection with validation
get_selection() {
    local -n __options=$1
    local prompt=$2
    
    local choice
    while :; do
        choice=$(printf "%s\n" "${__options[@]}" | rofi -dmenu -p "${prompt}" -theme-str 'listview { lines: 5; }')
        [[ -z "${choice}" ]] && { dunstify "Selection cancelled" --urgency=low; exit 1; }
        
        # Validate against original options
        for item in "${__options[@]}"; do
            [[ "${item}" == "${choice}" ]] && return 0
        done
        
        dunstify "Invalid selection" "Please choose from the list" --urgency=critical
    done
}

# Generate filename components
generate_filename() {
    local quality=$1 fps=$2 audio_opt=$3
    
    local resolution
    resolution=$(xdpyinfo | awk -F'[ x]+' '/dimensions/{print $2"x"$3}') || {
        dunstify "Error" "Failed to get screen resolution" --urgency=critical
        exit 1
    }
    
    local datetime
    datetime=$(date '+%Y.%m.%d_%H-%M-%S')  # Colon-free timestamp for filesystem safety
    
    printf "%s/ScreenRecord_%s_%s_%dfps_%s_%s.mkv" \
        "${OUTPUT_DIR}" "${datetime}" "${resolution}" "${fps}" "${quality}" "${audio_opt}"
}

# Main recording function
start_recording() {
    check_dependencies

    # Quality selection
    local quality_options=("${!QUALITY_PRESETS[@]}")
    get_selection quality_options "Select Quality:"
    local quality="${choice}"
    IFS=':' read -r preset crf <<< "${QUALITY_PRESETS[${quality}]}"

    # FPS selection
    get_selection VALID_FPS "Select FPS:"
    local fps="${choice}"

    # Audio selection
    local audio_options=("Yes" "No")
    get_selection audio_options "Include Audio?"
    local audio_opt="${choice}"
    local audio_input=()
    [[ "${audio_opt}" == "Yes" ]] && audio_input=(-f pulse -i default)

    # Create output directory
    mkdir -p "${OUTPUT_DIR}" || {
        dunstify "Error" "Failed to create output directory" --urgency=critical
        exit 1
    }

    # Generate filename
    local output_file
    output_file=$(generate_filename "${quality}" "${fps}" "${audio_opt,,}") || exit 1

    # Notification
    dunstify "Starting Recording" "\nQuality: ${quality}\nFPS: ${fps}\nAudio: ${audio_opt}" \
        --urgency=low --appname="Screen Recorder"

    # FFmpeg command array
    local ffmpeg_cmd=(
        ffmpeg -hide_banner -loglevel error -stats
        -probesize 50M -thread_queue_size 1024
        -f x11grab -video_size "$(xdpyinfo | grep dimensions | awk '{print $2}')"
        -framerate "${fps}" -i "${DISPLAY}"
        "${audio_input[@]}"
        -c:v libx264 -preset "${preset}" -crf "${crf}" -pix_fmt yuv420p
        -c:a flac -compression_level 8
        -af "aresample=async=1:min_hard_comp=0.100000:first_pts=0"
        -avoid_negative_ts make_zero -fflags +genpts
        "${output_file}"
    )

    # Run FFmpeg and capture exit code
    if "${ffmpeg_cmd[@]}"; then
        dunstify "Recording Complete" "Saved to:\n${output_file}" \
            --urgency=normal --appname="Screen Recorder"
    else
        local ec=$?
        dunstify "Recording Failed" "Error code: ${ec}\nCheck terminal for details" \
            --urgency=critical --appname="Screen Recorder"
        exit ${ec}
    fi
}

# Main execution with signal handling
trap 'dunstify "Recording Aborted" --urgency=critical; exit 130' INT TERM
start_recording
