#!/usr/bin/env bash
# shellcheck disable=SC2199
set -euo pipefail

# Define directories
readonly qtheme_dir="$HOME/.qtheme"
readonly wallpaper_dir="$HOME/.wallpaper"
readonly config_dir="$HOME/.config"

# Validate required directories
check_dirs() {
    local dirs=("$qtheme_dir" "$wallpaper_dir" "$config_dir")
    for dir in "${dirs[@]}"; do
        if [[ ! -d "$dir" ]]; then
            echo "Error: Required directory '$dir' not found" >&2
            exit 1
        fi
    done
}

# Select theme using rofi
select_theme() {
    local themes=()
    mapfile -t themes < <(find "$qtheme_dir" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort)
    
    if [[ ${#themes[@]} -eq 0 ]]; then
        echo "No themes found in $qtheme_dir" >&2
        exit 1
    fi

    local selected
    selected=$(printf "%s\n" "${themes[@]}" | rofi -dmenu -p "Select Theme:")
    
    if [[ -z "$selected" ]]; then
        echo "No theme selected" >&2
        exit 1
    fi
    echo "$selected"
}

# Apply selected theme
apply_theme() {
    local theme="$1"
    local src="$qtheme_dir/$theme"
    local dest="$config_dir"

    if [[ ! -d "$src" ]]; then
        echo "Theme directory not found: $src" >&2
        exit 1
    fi

    # Copy theme files
    cp -r "$src/." "$dest"

    # Set theme-specific settings
    case "$theme" in
        "redrose")   set_theme "adw-gtk3-red" "Tela-red" ;;
        "bluerod")   set_theme "adw-gtk3-blue" "Tela-purple" ;;
        "nyoom")     set_theme "adw-gtk3-dark" "Tela-black" ;;
        *)           echo "Warning: No specific settings for theme: $theme" ;;
    esac
}

# Helper function to set theme properties
set_theme() {
    gsettings set org.gnome.desktop.interface gtk-theme "$1"
    gsettings set org.gnome.desktop.interface icon-theme "$2"
}

# Select wallpaper using rofi
select_wallpaper() {
    local wallpapers=()
    mapfile -t wallpapers < <(find "$wallpaper_dir" -type f -printf '%f\n' | sort)
    
    if [[ ${#wallpapers[@]} -eq 0 ]]; then
        echo "No wallpapers found in $wallpaper_dir" >&2
        return 1
    fi

    local selected
    selected=$(printf "%s\n" "${wallpapers[@]}" | rofi -dmenu -p "Select Wallpaper:")
    
    if [[ -n "$selected" ]]; then
        feh --bg-fill "$wallpaper_dir/$selected"
        echo "Wallpaper set: $selected"
    fi
}

# Restart Qtile and related processes
restart_environment() {
    # Update user directories
    xdg-user-dirs-update
    xdg-user-dirs-gtk-update

    # Restart Qtile
    qtile cmd-obj -f restart

    # Gracefully restart processes
    local processes=(xsettingsd alacritty firefox dunst thunar ksuperkey)
    for proc in "${processes[@]}"; do
        if pidof "$proc" >/dev/null; then
            killall "$proc"
        fi
    done
}

main() {
    check_dirs
    local theme
    theme=$(select_theme)
    apply_theme "$theme"
    select_wallpaper
    restart_environment
}

main "$@"
