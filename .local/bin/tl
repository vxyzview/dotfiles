#!/bin/bash

# Configuration
CONFIG_FILE="$HOME/.translator.conf"
HISTORY_FILE="$HOME/.translation_history"
MAX_HISTORY=100

# Colors and formatting
bold=$(tput bold)
reset=$(tput sgr0)
cyan=$(tput setaf 6)
green=$(tput setaf 2)
yellow=$(tput setaf 3)
red=$(tput setaf 1)
purple=$(tput setaf 5)

# Dependency check
check_dependencies() {
    local deps=("curl" "jq" "xclip")
    for dep in "${deps[@]}"; do
        if ! command -v "$dep" &> /dev/null; then
            echo -e "${red}Error: Missing required dependency - $dep${reset}"
            exit 1
        fi
    done
}

# Load configuration
load_config() {
    [[ -f "$CONFIG_FILE" ]] || return
    source "$CONFIG_FILE"
    DEFAULT_SOURCE_LANG=${DEFAULT_SOURCE_LANG:-auto}
    DEFAULT_TARGET_LANG=${DEFAULT_TARGET_LANG:-en}
}

# Save configuration
save_config() {
    cat > "$CONFIG_FILE" <<-EOF
DEFAULT_SOURCE_LANG="$DEFAULT_SOURCE_LANG"
DEFAULT_TARGET_LANG="$DEFAULT_TARGET_LANG"
EOF
}

# Language detection
detect_language() {
    local text="$1"
    local url="https://translate.googleapis.com/translate_a/single?client=gtx&q=$(jq -rn --arg text "$text" '$text | @uri')&dt=ld"
    curl -s "$url" | jq -r '.ld_result.srclangs[0]'
}

# Translation core
translate() {
    local sl="$1" tl="$2" text="$3"
    local url="https://translate.googleapis.com/translate_a/single?client=gtx&sl=$sl&tl=$tl&dt=t&dt=rm&q=$(jq -rn --arg text "$text" '$text | @uri')"
    
    local response=$(curl -sS --fail "$url")
    [ $? -ne 0 ] && { echo -e "${red}Translation failed${reset}"; exit 1; }
    
    local translation=$(jq -r '.[0][][0]' <<< "$response")
    local pronunciation=$(jq -r '.[1][][2]' <<< "$response")
    echo -e "$translation\n${purple}Pronunciation: $pronunciation${reset}"
}

# Interactive mode
interactive_mode() {
    echo -e "${cyan}${bold}Enter text to translate (Ctrl+D to finish):${reset}"
    local text=$(cat)
    [ -z "$text" ] && { echo -e "${red}No input text${reset}"; exit 1; }

    if [[ "$DEFAULT_SOURCE_LANG" == "auto" ]]; then
        echo -e "${yellow}Detecting language...${reset}"
        DEFAULT_SOURCE_LANG=$(detect_language "$text")
    fi

    local output=$(translate "$DEFAULT_SOURCE_LANG" "$DEFAULT_TARGET_LANG" "$text")
    echo -e "\n${green}${bold}Translation (${DEFAULT_SOURCE_LANG} → ${DEFAULT_TARGET_LANG}):${reset}\n$output"
    
    echo -n "$output" | xclip -selection clipboard && echo -e "${green}Copied to clipboard!${reset}"
    
    # Save to history
    echo "[$(date +"%Y-%m-%d %H:%M:%S")] ${DEFAULT_SOURCE_LANG} → ${DEFAULT_TARGET_LANG}: $text → $output" >> "$HISTORY_FILE"
    tail -n $MAX_HISTORY "$HISTORY_FILE" > "${HISTORY_FILE}.tmp" && mv "${HISTORY_FILE}.tmp" "$HISTORY_FILE"
}

# Command-line mode
cli_mode() {
    local sl="$DEFAULT_SOURCE_LANG" tl="$DEFAULT_TARGET_LANG" text
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f|--from) sl="$2"; shift 2 ;;
            -t|--to) tl="$2"; shift 2 ;;
            -h|--help) show_help; exit 0 ;;
            *) text="$1"; shift ;;
        esac
    done

    [ -z "$text" ] && { [ -t 0 ] && interactive_mode || exit 1; }
    [[ "$sl" == "auto" ]] && sl=$(detect_language "$text")
    
    local output=$(translate "$sl" "$tl" "$text")
    echo -e "$output"
}

show_help() {
    echo -e "${bold}Usage:${reset}"
    echo "  translator [OPTIONS] [TEXT]"
    echo -e "\n${bold}Options:${reset}"
    echo "  -f, --from LANG    Source language (default: auto-detect)"
    echo "  -t, --to LANG      Target language (default: $DEFAULT_TARGET_LANG)"
    echo "  -h, --help         Show this help"
    echo -e "\n${bold}Examples:${reset}"
    echo "  translator -f en -t es \"Hello World\""
    echo "  translator -t fr < document.txt"
    echo "  echo \"Bonjour\" | translator -t de"
}

# Main execution
main() {
    check_dependencies
    load_config
    
    if [ $# -eq 0 ]; then
        interactive_mode
    else
        cli_mode "$@"
    fi
    
    save_config
}

main "$@"
