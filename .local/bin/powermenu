#!/usr/bin/env bash
# shellcheck disable=SC2199,SC2162

SCRIPT_NAME="󰒓 Power Menu"
CONFIRM_TIMEOUT=5000  # milliseconds
ROFI_THEME="window {width: 15%;} listview {lines: 5;}"

declare -A ACTIONS=(
    ["󰐥 Poweroff"]="system_poweroff"
    ["󰜉 Reboot"]="system_reboot"
    ["󰤄 Suspend"]="system_suspend"
    ["󰤁 Hibernate"]="system_hibernate"
    ["󰍃 Lock"]="lock_screen"
    ["󰿅 Logout"]="user_logout"
)

declare -A COMMANDS=()
declare -A ICONS=(
    [confirm]="󰄬" [success]="󰄬" [error]="󰚌" 
    [warning]="󰚌" [cancel]="󰅖"
)

detect_init_system() {
    [[ -x /sbin/openrc-init ]] && { echo "openrc"; return; }
    command -v systemctl &>/dev/null && { echo "systemd"; return; }
    command -v loginctl &>/dev/null && { echo "logind"; return; }
    exit_error "No supported init system found"
}

setup_commands() {
    local init_system=$1
    case $init_system in
        systemd)
            COMMANDS=(
                [system_poweroff]="systemctl poweroff"
                [system_reboot]="systemctl reboot"
                [system_suspend]="systemctl suspend"
                [system_hibernate]="systemctl hibernate"
                [user_logout]="loginctl terminate-session ${XDG_SESSION_ID-}"
            ) ;;
        logind|openrc)
            COMMANDS=(
                [system_poweroff]="loginctl poweroff"
                [system_reboot]="loginctl reboot"
                [system_suspend]="loginctl suspend"
                [system_hibernate]="loginctl hibernate"
                [user_logout]="loginctl terminate-session ${XDG_SESSION_ID-}"
            ) ;;
    esac
}

lock_screen() {
    local lockers=(
        "swaylock -f -c 000000"
        "i3lock -c 000000 -n"
        "loginctl lock-session"
        "xdg-screensaver lock"
    )
    
    for locker in "${lockers[@]}"; do
        command -v ${locker%% *} &>/dev/null && {
            $locker
            return $?
        }
    done
    
    exit_error "No screen locker found"
}

exit_error() {
    dunstify -u critical -t "$CONFIRM_TIMEOUT" \
        "${ICONS[error]} ${1:-Critical Error}"
    exit 1
}

confirm_action() {
    local action=$1
    local response=$(printf "󰌾 Confirm\n󰅖 Cancel" | rofi -dmenu -i -p "${ICONS[warning]} $action" -theme-str "$ROFI_THEME")
    [[ "$response" == "󰌾 Confirm" ]]
}

handle_action() {
    local action=$1
    case $action in
        system_*|user_*)
            ${COMMANDS[$action]} && {
                dunstify -u normal -t "$CONFIRM_TIMEOUT" \
                    "${ICONS[success]} ${action//_/ } initiated"
                return 0
            } ;;
        lock_screen)
            lock_screen ;;
        *)
            exit_error "Invalid action: $action" ;;
    esac
}

show_menu() {
    local selection
    selection=$(printf "%s\n" "${!ACTIONS[@]}" | rofi -dmenu -i -p "$SCRIPT_NAME" -theme-str "$ROFI_THEME")
    [[ -z "$selection" ]] && exit 0

    local action=${ACTIONS[$selection]}
    confirm_action "${selection#* }" && handle_action "$action" || {
        dunstify -u low -t "$CONFIRM_TIMEOUT" \
            "${ICONS[cancel]} Operation canceled"
    }
}

# Main Execution
init_system=$(detect_init_system)
setup_commands "$init_system"
show_menu

exit 0
