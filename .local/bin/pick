#!/bin/bash

# Enable strict error handling
set -euo pipefail

# Check if gpick is available
if ! command -v gpick &>/dev/null; then
    notify-send "Error" "gpick is not installed!"
    exit 1
fi

# Get color and trim whitespace using command substitution
color=$(gpick --pick --single --output)

# Check if color selection was aborted
if [[ -z "${color}" ]]; then
    notify-send "Color Picking Aborted" "No color was selected."
    exit 0
fi

# Copy to clipboard using POSIX-compliant printf
printf "%s" "${color}" | xclip -selection clipboard

# Send notification
notify-send "Color Picked!" "Color '${color}' copied to clipboard."
