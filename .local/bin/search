#!/bin/bash

declare -A browsers=(
    ["Google"]="https://www.google.com/search?q="
    ["YouTube"]="https://www.youtube.com/results?search_query="
    ["TikTok"]="https://www.tiktok.com/tag/"
    ["DuckDuckGo"]="https://duckduckgo.com/?q="
    ["Yandex"]="https://yandex.com/search/?text="
    ["Mangadex"]="https://mangadex.org/search?title="
    ["GitHub"]="https://github.com/search?q="
    ["Spotify"]="https://open.spotify.com/search/"
    ["W3Schools"]="https://www.w3schools.com/"
    ["StackOverflow"]="https://stackoverflow.com/search?q="
    ["CodePen.io"]="https://codepen.io/search/pens?q="
)

# Select browser using rofi
selected_browser=$(printf "%s\n" "${!browsers[@]}" | rofi -dmenu -p "Select browser:")

# Exit if no browser selected or invalid selection
[[ -z "$selected_browser" || ! -v browsers["$selected_browser"] ]] && exit 0

# Get search term
search_term=$(rofi -dmenu -p "Search term:")

# Exit if no search term entered
[[ -z "$search_term" ]] && exit 0

# Construct URL
base_url="${browsers["$selected_browser"]}"
encoded_term="${search_term// /+}"
full_url="$base_url$encoded_term"

# Open in default browser
xdg-open "$full_url"
